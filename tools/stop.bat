@echo off
@rem 文字化け防止
chcp 65001 >nul

echo ==========================================
echo       ゲームサーバー停止ツール
echo ==========================================
echo.

echo "[1/2] 実行中のサーバーを探して停止しています..."
docker stop game-api >nul 2>&1

echo "[2/2] 不要な一時ファイルを削除しています..."
docker rm game-api >nul 2>&1

echo.
echo "------------------------------------------"
echo "✅ サーバーは安全に停止されました。"
echo.
echo "※ もしエラーが出ていた場合は、この画面を閉じてから"
echo "  再度 start.bat を試してください。"
echo "------------------------------------------"
echo.
pause